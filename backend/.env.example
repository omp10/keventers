# ─────────────────────────────────────────────────────────────
# Keventers Smart Ordering Platform — Environment Template
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# Every key here is validated by src/config/env.schema.js at boot.
# ─────────────────────────────────────────────────────────────

# --- Server ---
# For a production split where the frontend is deployed on Vercel and only the
# backend runs on your VPS, set NODE_ENV=production and replace wildcard CORS
# values with your exact Vercel domain(s).
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
API_PREFIX=/api
BODY_LIMIT=1mb
CORS_ORIGIN=*
SHUTDOWN_TIMEOUT_MS=10000

# --- MongoDB ---
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=keventers
MONGO_MAX_POOL_SIZE=10
MONGO_MIN_POOL_SIZE=2
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=keventers:

# --- JWT (placeholder auth wiring for future identity module) ---
JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=keventers-platform
JWT_AUDIENCE=keventers-clients

# --- Logging ---
LOG_LEVEL=debug
LOG_PRETTY=true

# --- Swagger / OpenAPI ---
SWAGGER_ENABLED=true
SWAGGER_ROUTE=/docs

# --- Auth / Session ---
SESSION_TTL_SECONDS=604800
AUTH_MAX_SESSIONS_PER_USER=10
BCRYPT_SALT_ROUNDS=12

# --- Security (optional; required only when the corresponding feature is used) ---
ENCRYPTION_KEY=change-me-encryption-key-at-least-32-chars
API_KEY_PEPPER=change-me-api-key-pepper

# --- File Storage ---
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./uploads
STORAGE_PUBLIC_BASE_URL=http://localhost:4000/static
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=

# --- Socket.IO ---
SOCKET_PATH=/socket.io
SOCKET_CORS_ORIGIN=*
SOCKET_REDIS_ADAPTER=true

# --- Background Jobs / Queue (BullMQ) ---
QUEUE_PREFIX=keventers:jobs
QUEUE_DEFAULT_ATTEMPTS=3
QUEUE_DEFAULT_BACKOFF_MS=2000
QUEUE_REMOVE_ON_COMPLETE=1000
QUEUE_REMOVE_ON_FAIL=5000

# --- Event Bus ---
EVENT_MAX_RETRIES=3
EVENT_RETRY_BACKOFF_MS=200

# --- Observability ---
METRICS_ENABLED=true
METRICS_ROUTE=/metrics

# --- Platform Seed / Bootstrap Admin (used by `npm run seed`) ---
PLATFORM_ADMIN_NAME=Platform Super Admin
PLATFORM_ADMIN_EMAIL=admin@keventers.com
PLATFORM_ADMIN_PASSWORD=admin123
PLATFORM_ADMIN_PHONE=
# Optional default organization (deferred until the Organization module exists)
SEED_DEFAULT_ORG_ENABLED=false
SEED_DEFAULT_ORG_NAME=Keventers

# --- QR Ordering / Guest Sessions (Phase 4.4) ---
# Server-side secret for signing QR tokens (defaults to JWT_ACCESS_SECRET if unset)
QR_TOKEN_SECRET=
# Public base URL the physical QR image points to (customer scan landing).
# Example production value: https://api.keventers.example/scan
QR_PUBLIC_BASE_URL=http://localhost:4000/scan
GUEST_SESSION_TTL_SECONDS=7200
GUEST_SESSION_IDLE_TIMEOUT_SECONDS=1800
GUEST_TOKEN_EXPIRES_IN=2h
QR_SCAN_RATE_LIMIT=30
QR_SCAN_RATE_WINDOW_SECONDS=60

# --- Cart & Pricing (Phase 4.5) ---
CART_EXPIRATION_SECONDS=3600
CART_IDEMPOTENCY_TTL_SECONDS=86400
CART_LOCK_TTL_MS=5000
CART_MAX_ITEMS=100

# Phone sign-in without an SMS provider: use a FIXED code and echo it in the API
# response so the customer, kitchen and staff panels all accept the same number.
# Forced off in production regardless of what is set here.
MOCK_OTP=true
# The fixed code, while MOCK_OTP=true. Exactly 6 digits.
MOCK_OTP_CODE=000000
