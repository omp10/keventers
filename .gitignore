# Firebase / FCM service-account credentials — NEVER commit. Local dev reads the
# file via FCM_SERVICE_ACCOUNT_PATH; production passes FCM_SERVICE_ACCOUNT
# (base64) as a secret env var instead of shipping a file.
backend/config/firebase-service-account.json
