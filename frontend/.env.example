# Public build-time configuration only. Never put server secrets in VITE_* values.
VITE_APP_ENV=development
VITE_API_URL=http://localhost:4000/api/v1
VITE_API_VERSION=v1
VITE_API_TIMEOUT_MS=20000

VITE_SOCKET_URL=http://localhost:4000
VITE_SOCKET_PATH=/socket.io
VITE_SOCKET_ENABLED=true

VITE_GOOGLE_MAPS_API_KEY=
VITE_ANALYTICS_ENABLED=false
VITE_ANALYTICS_WRITE_KEY=

VITE_FF_PAYMENTS=true
VITE_FF_LOYALTY=true
VITE_FF_NOTIFICATIONS=true
VITE_FF_QR=true
VITE_FF_DISCOVERY=true
VITE_FF_MAPS=true
VITE_FF_ANALYTICS=true
VITE_FF_KITCHEN=true
VITE_FF_EXPERIMENTAL=false

# Microsoft Clarity project id. Empty = Clarity is not loaded (no third party
# receives session data). Get this from clarity.microsoft.com.
VITE_CLARITY_PROJECT_ID=

# ── Firebase Cloud Messaging (web push) ──────────────────────────────────────
# Public by design (Vite inlines these). Restrict the browser API key by HTTP
# referrer in Google Cloud Console. The var is VITE_FIREBASE_SENDER_ID — NOT
# VITE_FIREBASE_MESSAGING_SENDER_ID — matching src/config/env.ts.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Web Push certificate PUBLIC key (Cloud Messaging → Web Push certificates).
# The matching PRIVATE key is never used by the Firebase SDK — keep it out.
VITE_FIREBASE_VAPID_KEY=
